    function renderList() {
        sortableList.innerHTML = '';
        if (parsedItems.length === 0) {
            resultsSection.classList.add('hidden');
            return;
        }

        resultsSection.classList.remove('hidden');

        parsedItems.forEach((item, index) => {
            const li = document.createElement('li');
            li.className = 'list-item';
            li.draggable = true;
            li.dataset.index = index;

            // Drag events
            li.addEventListener('dragstart', handleDragStart);
            li.addEventListener('dragover', handleDragOver);
            li.addEventListener('drop', handleDrop);
            li.addEventListener('dragenter', (e) => e.preventDefault());

            const successClass = item.success ? 'status-success' : 'status-error';
            const statusText = item.success ? 'Başarılı' : 'Hata';
            const previewText = item.success ? item.texts.join(' ').substring(0, 80) + '...' : item.error;

            li.innerHTML = `
                <i class="fa-solid fa-grip-vertical drag-handle"></i>
                <div class="item-content">
                    <div class="item-title">
                        ${item.filename}
                        <span class="item-status ${successClass}">${statusText}</span>
                    </div>
                    <div class="item-preview" title="${item.success ? item.texts.join(' ') : item.error}">${previewText}</div>
                </div>
                <button class="remove-btn" onclick="removeItem(${index})"><i class="fa-solid fa-trash"></i></button>
            `;
            sortableList.appendChild(li);
        });
    }

    window.removeItem = (index) => {
        parsedItems.splice(index, 1);
        renderList();
    };

    // Drag to Reorder Logic
    let dragStartIndex;

    function handleDragStart(e) {
        dragStartIndex = +this.dataset.index;
        e.dataTransfer.effectAllowed = 'move';
        setTimeout(() => this.classList.add('dragging'), 0);
    }

    function handleDragOver(e) {
        e.preventDefault();
    }

    function handleDrop(e) {
        e.preventDefault();
        this.classList.remove('dragging');
        const dragEndIndex = +this.dataset.index;
        swapItems(dragStartIndex, dragEndIndex);
    }
    
    document.addEventListener('dragend', (e) => {
        document.querySelectorAll('.list-item').forEach(li => li.classList.remove('dragging'));
    });

    function swapItems(fromIndex, toIndex) {
        const itemOne = parsedItems[fromIndex];
        parsedItems.splice(fromIndex, 1);
        parsedItems.splice(toIndex, 0, itemOne);
        renderList();
    }

    // Generate DOCX
    generateBtn.addEventListener('click', async () => {
        const validItems = parsedItems.filter(i => i.success);
        if (validItems.length === 0) {
            alert('Lütfen word belgesi oluşturmak için en az bir geçerli SVG yükleyin.');
            return;
        }

        loadingOverlay.classList.remove('hidden');

        try {
            const baseUrl = window.location.origin.includes('5173') || window.location.pathname.endsWith('index.html') 
                ? 'http://localhost:8000' 
                : '';
            
            const response = await fetch(`${baseUrl}/api/generate-docx`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: validItems })
            });

            if (!response.ok) throw new Error("Sunucu hatası.");
            
            // Download Blob
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = "Converted.docx";
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            a.remove();
        } catch (error) {
            console.error(error);
            alert("Word belgesi oluşturulurken hata meydana geldi.");
        } finally {
            loadingOverlay.classList.add('hidden');
        }
    });


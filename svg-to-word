import requests

def extract_text_from_svg(svg_content: bytes) -> list:
    """Parses SVG and extracts all nested <text> and <tspan> strings."""
    try:
        soup = BeautifulSoup(svg_content, 'lxml-xml')
    except Exception:
        # Fallback to html parser if lxml is not perfectly working
        soup = BeautifulSoup(svg_content, 'html.parser')
        
    extracted = []
    
    # 1. Klasik SVG text elementleri
    texts = soup.find_all(['text', 'tspan'])
    if texts:
        for t in texts:
            text_val = t.get_text(strip=True)
            if text_val:
                extracted.append(text_val)
    
    # 2. Eğer foreignObject veya HTML kullanıldıysa
    if not extracted:
        foreign_objects = soup.find_all('foreignObject')
        for fo in foreign_objects:
            text_val = fo.get_text(separator=" ", strip=True)
            if text_val:
                extracted.append(text_val)
                
    # 3. Son çare olarak belgedeki tüm düz metin düğümlerini al
    if not extracted:
        all_text = soup.get_text(separator=" ", strip=True)
        if all_text and len(all_text) > 2: # rastgele kısa semboller hariç
            extracted.append(all_text)
            
    # 4. Hiç metin bulunamadı, demek ki şekillere dönüştürülmüş (OCR kullan)
    if not extracted:
        try:
            svg_io = io.BytesIO(svg_content)
            drawing = svg2rlg(svg_io)
            if drawing:
                png_io = io.BytesIO()
                renderPM.drawToFile(drawing, png_io, fmt="PNG")
                png_data = png_io.getvalue()
                
                # API Call to OCR Space
                payload = {
                    'apikey': 'K88674996488957',
                    'language': 'tur',
                    'base64Image': 'data:image/png;base64,' + base64.b64encode(png_data).decode('utf-8'),
                    'OCREngine': '2'
                }
                
                res = requests.post('https://api.ocr.space/parse/image', data=payload, timeout=15)
                if res.status_code == 200:
                    data = res.json()
                    if not data.get('IsErroredOnProcessing'):
                        parsed_text = data['ParsedResults'][0]['ParsedText']
                        if parsed_text.strip():
                            extracted.append(parsed_text.strip())
        except Exception as e:
            print("OCR hatası:", e)
            
    return extracted

def build_docx(items: list) -> io.BytesIO:
    """Creates a Word document from parsed SVG items."""
    document = Document()
    
    heading = document.add_heading('SVG Metin Çıktıları', 0)
    
    for item in items:
        filename = item.get("filename", "Bilinmeyen Dosya")
        texts = item.get("texts", [])
        
        p = document.add_paragraph()
        runner = p.add_run(filename)
        runner.bold = True
        runner.font.size = Pt(14)
        
        if texts:
            content_p = document.add_paragraph()
            content_p.add_run(" ".join(texts))
        else:
            p2 = document.add_paragraph()
            r2 = p2.add_run("Metin bulunamadı.")
            r2.italic = True
            
        document.add_paragraph()
        
    output = io.BytesIO()
    document.save(output)
    output.seek(0)
    
    return output



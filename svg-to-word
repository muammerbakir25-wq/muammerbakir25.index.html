from typing import List
from fastapi import APIRouter, File, UploadFile, HTTPException
from fastapi.responses import StreamingResponse
from pydantic import BaseModel
from services import extract_text_from_svg, build_docx

router = APIRouter()

class DocumentItem(BaseModel):
    filename: str
    texts: List[str]

class GenerateRequest(BaseModel):
    items: List[DocumentItem]

@router.post("/parse-svgs")
async def parse_svgs(files: List[UploadFile] = File(...)):
    results = []
    
    for file in files:
        if not file.filename.lower().endswith(".svg"):
            results.append({
                "filename": file.filename,
                "success": False,
                "error": "Sadece SVG desteklenmektedir."
            })
            continue
            
        content = await file.read()
        try:
            texts = extract_text_from_svg(content)
            if not texts:
                results.append({
                    "filename": file.filename,
                    "success": False,
                    "error": "Okunabilir metin bulunamadı."
                })
            else:
                results.append({
                    "filename": file.filename,
                    "success": True,
                    "texts": texts
                })
        except Exception as e:
            results.append({
                "filename": file.filename,
                "success": False,
                "error": f"Hata: {str(e)}"
            })
            
    return {"data": results}

@router.post("/generate-docx")
async def generate_docx(req: GenerateRequest):
    items = [item.dict() for item in req.items]
    if not items:
        raise HTTPException(status_code=400, detail="Veri listesi boş.")
        
    doc_io = build_docx(items)
    
    return StreamingResponse(
        doc_io, 
        media_type="application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        headers={
            "Content-Disposition": "attachment; filename=Converted.docx"
        }
    )

